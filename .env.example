# === 安全密鑰 ===
# 必須設定：使用強隨機字符串，長度 >= 32 字元
JWT_SECRET=your-long-random-secret-key-here-min-32-chars
GEMINI_API_KEY=your-gemini-api-key-here
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# === 應用配置 ===
NODE_ENV=development
PORT=8050
HOST=127.0.0.1
DB_FILE=medremind.db
CREATE_DEMO_DATA=true

# === 管理員帳號（production 必填）===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=系統管理員

# === 密碼雜湊 ===
SALT_ROUNDS=12
LEGACY_PASSWORD_SALT=legacy-salt-for-one-time-password-migration

# === 資料庫配置 ===
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=86400000

# === CORS 配置 ===
ALLOWED_ORIGINS=http://localhost:8050,http://localhost:3000,https://yaojidecare.app,https://www.yaojidecare.app,capacitor://localhost,ionic://localhost

# === 審計日誌 ===
AUDIT_LOGGING_ENABLED=true
